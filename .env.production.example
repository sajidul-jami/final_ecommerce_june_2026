# MySQL
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_PORT=3306
DB_NAME=ecommerce
DB_USER=root

# JWT secrets
USER_JWT_SECRET=change_me_user_jwt_secret
ADMIN_JWT_SECRET=change_me_admin_jwt_secret

# Host ports
USER_FRONTEND_PORT=3000
USER_BACKEND_PORT=3005
ADMIN_FRONTEND_PORT=3002
ADMIN_BACKEND_PORT=3001

# Public URLs (used at frontend build time and for CORS)
NEXT_PUBLIC_SITE_URL=https://shop.example.com
NEXT_PUBLIC_USER_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_ADMIN_API_URL=https://admin-api.example.com/api
NEXT_PUBLIC_ADMIN_UPLOAD_URL=https://admin-api.example.com/upload
NEXT_PUBLIC_PRODUCT_IMAGE_BASE_URL=https://cdn.example.com/products/images/productsimg

# CORS
ADMIN_CLIENT_URL=https://admin.example.com
USER_CORS_ORIGINS=https://shop.example.com
ADMIN_CORS_ORIGINS=https://admin.example.com

# MinIO (included as a container in docker-compose.production.yml)
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key
MINIO_PUBLIC_URL=https://cdn.example.com
